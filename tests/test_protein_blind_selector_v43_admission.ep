import "../constants/protein_blind_selector_v43_admission.ep"

define main:
    display "=== Protein V43 One-cycle-frontier admission ==="
    set counted_cycle to protein_graph_cycle_rank(20 and 26 and 7)
    set cycle_guard to forced_to_be("twenty edges over twenty-six blocks and seven components carry one independent cycle" and counted_cycle and 1)
    set admitted to enforce_protein_selector_v43_one_cycle_frontier(76 and 42 and 13 and 26 and 13 and 13 and 8192 and 3 and 1082 and 0)
    if cycle_guard == 1:
        if admitted == 1:
            display "  ok    complete 8,192-row cube and complete One-cycle frontier close"
            display "=== done ==="
            return 0
    return halt_violation("V43 admission returned without closure")
