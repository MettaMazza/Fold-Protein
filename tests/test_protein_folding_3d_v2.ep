import "../constants/protein_folding_3d_v2.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        set halted to halt_violation(concat("protein angle equality failed: " and concat(label and concat(" got " and got))))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        set halted to halt_violation(concat("protein angle check failed: " and label))
    return 0
define main:
    display "=== 3D protein folding ==="
    set ok to expect_bool("alpha-helix phi folds to 1/3 (period-2 orbit)" and alpha_phi_folds_to_orbit())
    set ok to expect_bool("alpha-helix psi decays to native (1)" and alpha_psi_folds_to_native())
    set ok to expect_bool("beta-sheet phi folds to 2/3 (period-2 orbit)" and beta_phi_folds_to_orbit())
    set ok to expect_bool("beta-sheet psi decays to native (1)" and beta_psi_folds_to_native())
    set ok to expect_bool("angle lattice is assembled from the binary and colour counts" and protein_angle_lattice_count() == whole_power(binary_count() and colour_count()) * colour_count())
    set ok to expect_bool("homochiral signed-chart orientation has one complete candidate" and protein_homochiral_sign_candidate_count() == 1)
    set ok to expect_bool("opposite signed-chart orientation has one complete candidate" and protein_opposite_sign_candidate_count() == 1)
    set ok to expect_bool("alpha phi has one form in the complete signed lattice" and alpha_phi_form_candidate_count() == 1)
    set ok to expect_bool("alpha psi has one form in the complete signed lattice" and alpha_psi_form_candidate_count() == 1)
    set ok to expect_bool("beta phi has one form in the complete signed lattice" and beta_phi_form_candidate_count() == 1)
    set ok to expect_bool("beta psi has one form in the complete signed lattice" and beta_psi_form_candidate_count() == 1)
    set ok to expect_bool("canonical coordinates match the independently assembled indices" and canonical_angle_coordinates_match_forced_indices())
    set ok to expect_bool("canonical angle forms pass the engine admission guard" and enforce_canonical_angle_form_uniqueness() == 1)
    display "=== done ==="
    return 0
