import "../constants/protein_blind_selector_v39_admission.ep"

define expect_number with label as Str and got as Int and want as Int:
    if got equals want:
        display concat("  ok    " and concat(label and concat(" = " and int_to_string(got))))
    else:
        return halt_violation(concat("V39 admission count failed: " and label))
    return 0

define main:
    display "=== Protein V39 peptide-causal reconciliation admission ==="
    set ok to expect_number("phi causal event rank" and protein_phi_causal_event_rank() and 3)
    set ok to expect_number("psi causal event rank" and protein_psi_causal_event_rank() and 4)
    set ok to expect_number("positive chain directions" and protein_positive_chain_direction_candidate_count() and 1)
    set ok to expect_number("causal V38 fixed points" and protein_causal_fixed_point_candidate_count() and 1)
    set admitted to enforce_protein_selector_v39_causal_reconciliation(76)
    if admitted == 1:
        display "  ok    unique N-to-C phi-before-psi fixed point closes through the engine"
        display "=== done ==="
        return 0
    return halt_violation("V39 admission returned without closure")
